<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Blank's Roleplay Proxy</title>
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@300;400;600;700;800;900&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Nunito', 'Segoe UI', sans-serif; min-height: 100vh;
      background:
        radial-gradient(ellipse at 15% 50%, rgba(100,190,255,0.35) 0%, transparent 55%),
        radial-gradient(ellipse at 85% 15%, rgba(160,225,255,0.4) 0%, transparent 50%),
        radial-gradient(ellipse at 55% 85%, rgba(80,210,195,0.25) 0%, transparent 50%),
        linear-gradient(155deg, #a0d8f0 0%, #c2e8f8 35%, #cff0e8 65%, #b5dff5 100%);
      background-attachment: fixed; color: #0d2a3a; overflow-x: hidden;
    }
    #bg-canvas { position: fixed; inset: 0; z-index: 0; pointer-events: none; }
    .page { position: relative; z-index: 1; max-width: 1100px; margin: 0 auto; padding: 2rem 1.5rem 4rem; }

    /* Header */
    .header { text-align: center; margin-bottom: 2.2rem; }
    .header-glass {
      display: inline-block;
      background: linear-gradient(160deg, rgba(255,255,255,0.72), rgba(210,240,255,0.52));
      border: 2px solid rgba(255,255,255,0.88); border-radius: 26px;
      padding: 1.2rem 3rem; backdrop-filter: blur(14px);
      box-shadow: 0 10px 36px rgba(40,120,200,0.18), inset 0 2px 0 rgba(255,255,255,0.95);
    }
    .header-title {
      font-size: 2rem; font-weight: 900;
      background: linear-gradient(135deg, #1060a0, #0d9e8a, #1878c0);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    }
    .header-sub { font-size: 0.83rem; font-weight: 600; color: #3a7090; margin-top: 0.2rem; }
    .status-clock {
      display: inline-flex; align-items: center; gap: 8px; margin-top: 0.65rem;
      font-size: 0.78rem; font-weight: 700;
      background: rgba(100,230,180,0.28); border: 1.5px solid rgba(80,210,160,0.52);
      border-radius: 99px; padding: 4px 14px;
    }
    .status-dot { width: 7px; height: 7px; border-radius: 50%; background: radial-gradient(circle at 35% 35%, #4de8a0, #0d9e6e); box-shadow: 0 0 7px rgba(13,158,110,0.8); animation: pulse 2s ease-in-out infinite; }
    @keyframes pulse { 0%,100% { transform: scale(1); } 50% { transform: scale(0.82); } }
    .status-divider { width: 1px; height: 13px; background: rgba(60,160,110,0.35); }
    .clock-text { color: #1a4a60; font-size: 0.78rem; }

    /* Tabs */
    .tabs { display: flex; gap: 8px; justify-content: center; margin-bottom: 1.8rem; flex-wrap: wrap; }
    .tab-btn { padding: 0.55rem 1.7rem; border-radius: 99px; border: 2px solid rgba(255,255,255,0.75); background: rgba(255,255,255,0.4); color: #1a5a80; font-family: 'Nunito', sans-serif; font-size: 0.88rem; font-weight: 800; cursor: pointer; backdrop-filter: blur(8px); transition: all 0.2s ease; box-shadow: 0 3px 10px rgba(60,130,200,0.1), inset 0 1px 0 rgba(255,255,255,0.8); }
    .tab-btn:hover { background: rgba(255,255,255,0.6); transform: translateY(-1px); }
    .tab-btn.active { background: linear-gradient(160deg, rgba(255,255,255,0.88), rgba(215,240,255,0.72)); border-color: rgba(255,255,255,0.98); color: #0d5a9a; box-shadow: 0 5px 20px rgba(60,140,220,0.25), inset 0 1px 0 rgba(255,255,255,1); transform: translateY(-2px); }
    .tab-panel { display: none; }
    .tab-panel.active { display: block; }

    /* Glass card */
    .glass-card { background: linear-gradient(150deg, rgba(255,255,255,0.62), rgba(220,242,255,0.48)); border: 2px solid rgba(255,255,255,0.78); border-radius: 20px; backdrop-filter: blur(14px); box-shadow: 0 8px 32px rgba(40,120,200,0.13), inset 0 2px 0 rgba(255,255,255,0.95); padding: 1.5rem; margin-bottom: 1.2rem; }
    .card-title { font-size: 0.72rem; font-weight: 800; text-transform: uppercase; letter-spacing: 1.1px; color: #3a6a88; margin-bottom: 1rem; }

    /* Stats */
    .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(155px, 1fr)); gap: 1rem; margin-bottom: 1.2rem; }
    .stat-card { background: linear-gradient(150deg, rgba(255,255,255,0.82), rgba(215,240,255,0.65)); border: 2px solid rgba(255,255,255,0.92); border-radius: 16px; padding: 1rem; text-align: center; box-shadow: 0 4px 16px rgba(60,130,200,0.1), inset 0 1px 0 rgba(255,255,255,1); transition: transform 0.2s ease; }
    .stat-card:hover { transform: translateY(-2px); }
    .stat-icon { font-size: 1.3rem; display: block; margin-bottom: 0.3rem; }
    .stat-label { font-size: 0.67rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.7px; color: #3a6a88; margin-bottom: 0.25rem; }
    .stat-value { font-size: 1.6rem; font-weight: 900; background: linear-gradient(135deg, #0d5a9a, #0b8a72); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; line-height: 1.1; }
    .stat-sub { font-size: 0.66rem; color: #5a8aaa; margin-top: 0.18rem; font-weight: 600; }

    /* Buttons */
    .btn { padding: 0.46rem 1.1rem; border-radius: 99px; border: 2px solid rgba(255,255,255,0.75); background: rgba(255,255,255,0.62); color: #0d3a5a; font-family: 'Nunito', sans-serif; font-size: 0.82rem; font-weight: 800; cursor: pointer; transition: all 0.18s ease; box-shadow: 0 2px 8px rgba(60,130,200,0.1), inset 0 1px 0 rgba(255,255,255,0.9); }
    .btn:hover { background: rgba(255,255,255,0.85); transform: translateY(-1px); }
    .btn:active { transform: translateY(0); }
    .btn.danger { color: #7a1a1a; border-color: rgba(255,170,170,0.6); background: rgba(255,225,225,0.55); }
    .btn.danger:hover { background: rgba(255,205,205,0.75); }
    .btn.primary { background: rgba(26,111,168,0.15); border-color: rgba(26,111,168,0.4); color: #0d5a9a; }
    .btn.primary:hover { background: rgba(26,111,168,0.25); }
    .btn.success { background: rgba(13,158,138,0.15); border-color: rgba(13,158,138,0.4); color: #0a6a58; }
    .btn.success:hover { background: rgba(13,158,138,0.25); }

    /* Log controls */
    .log-controls { display: flex; gap: 0.6rem; align-items: center; margin-bottom: 0.8rem; flex-wrap: wrap; }
    .log-count { margin-left: auto; font-size: 0.74rem; font-weight: 800; color: #2a5a78; }
    .filter-row { display: flex; gap: 0.45rem; margin-bottom: 0.85rem; flex-wrap: wrap; }
    .filter-pill { padding: 3px 13px; border-radius: 99px; font-size: 0.71rem; font-weight: 800; cursor: pointer; border: 1.5px solid transparent; opacity: 0.45; transition: all 0.15s ease; }
    .filter-pill.active { opacity: 1; }
    .filter-user   { background: rgba(60,140,240,0.16);  color: #0d3a8a; border-color: rgba(60,140,240,0.38); }
    .filter-bot    { background: rgba(20,180,140,0.16);  color: #0a4a38; border-color: rgba(20,180,140,0.38); }
    .filter-system { background: rgba(100,120,150,0.13); color: #2a3a4a; border-color: rgba(100,120,150,0.3); }
    .filter-error  { background: rgba(220,60,60,0.13);   color: #6a1010; border-color: rgba(220,60,60,0.3); }

    /* Log list */
    #log-list { display: flex; flex-direction: column; gap: 0.48rem; }
    .log-entry { background: rgba(255,255,255,0.84); border: 1.5px solid rgba(200,228,245,0.65); border-radius: 13px; overflow: hidden; transition: box-shadow 0.2s ease, transform 0.15s ease; box-shadow: 0 2px 7px rgba(60,120,200,0.07); }
    .log-entry:hover { transform: translateY(-1px); box-shadow: 0 4px 14px rgba(60,120,200,0.13); }
    .log-entry.type-user   { border-left: 4px solid #3c8cf0; }
    .log-entry.type-bot    { border-left: 4px solid #14b48c; }
    .log-entry.type-system { border-left: 4px solid #8090aa; }
    .log-entry.type-error  { border-left: 4px solid #e03c3c; }
    .log-header { display: flex; align-items: center; gap: 0.48rem; padding: 0.62rem 0.9rem; cursor: pointer; user-select: none; min-width: 0; }
    .log-pill { font-size: 0.59rem; font-weight: 900; text-transform: uppercase; letter-spacing: 0.7px; padding: 2px 8px; border-radius: 99px; flex-shrink: 0; width: 56px; text-align: center; }
    .pill-user   { background: rgba(60,140,240,0.18);  color: #0d3a8a; border: 1px solid rgba(60,140,240,0.32); }
    .pill-bot    { background: rgba(20,180,140,0.18);  color: #0a4a3a; border: 1px solid rgba(20,180,140,0.32); }
    .pill-system { background: rgba(100,120,150,0.15); color: #2a3a4a; border: 1px solid rgba(100,120,150,0.26); }
    .pill-error  { background: rgba(220,60,60,0.15);   color: #6a1010; border: 1px solid rgba(220,60,60,0.26); }
    .log-time    { font-size: 0.68rem; color: #2a5070; font-weight: 700; flex-shrink: 0; width: 74px; }
    .log-summary { flex: 1; font-size: 0.81rem; color: #0a2030; font-weight: 700; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; min-width: 0; }
    .log-cached  { font-size: 0.62rem; font-weight: 800; color: #4a0a8a; background: rgba(140,100,240,0.14); border: 1px solid rgba(140,100,240,0.3); border-radius: 99px; padding: 2px 8px; flex-shrink: 0; }
    .log-chevron { font-size: 0.62rem; color: #6a9aaa; flex-shrink: 0; transition: transform 0.2s; }
    .log-entry.expanded .log-chevron { transform: rotate(90deg); }
    .log-detail { display: none; padding: 0 0.9rem 0.9rem; border-top: 1px solid rgba(160,210,240,0.32); }
    .log-entry.expanded .log-detail { display: block; }
    .detail-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(100px, 1fr)); gap: 0.42rem; padding-top: 0.7rem; margin-bottom: 0.65rem; }
    .detail-chip { background: rgba(240,250,255,0.78); border: 1px solid rgba(180,220,245,0.5); border-radius: 10px; padding: 0.38rem 0.6rem; text-align: center; }
    .chip-label { font-size: 0.59rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.4px; color: #4a7a9a; }
    .chip-value { font-size: 0.84rem; font-weight: 800; color: #0d3a58; margin-top: 2px; }
    .msg-block { display: flex; align-items: center; background: rgba(255,255,255,0.62); border: 1px solid rgba(180,220,245,0.42); border-radius: 10px; padding: 0.52rem 0.82rem; margin-top: 0.42rem; gap: 0.72rem; }
    .msg-label { font-size: 0.59rem; font-weight: 900; text-transform: uppercase; letter-spacing: 0.7px; flex-shrink: 0; }
    .msg-label.user { color: #0d5a9a; } .msg-label.bot { color: #0a6a4a; }
    .msg-preview { flex: 1; font-size: 0.79rem; color: #1a3a50; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; min-width: 0; font-weight: 600; }
    .msg-btn { flex-shrink: 0; font-size: 0.69rem; font-weight: 800; color: #0d5a9a; background: rgba(60,140,240,0.12); border: 1px solid rgba(60,140,240,0.28); border-radius: 99px; padding: 3px 10px; cursor: pointer; font-family: 'Nunito', sans-serif; transition: all 0.15s ease; }
    .msg-btn:hover { background: rgba(60,140,240,0.22); }
    .sys-msg { font-size: 0.75rem; color: #2a4a5a; font-family: monospace; padding-top: 0.6rem; word-break: break-all; }

    /* Pagination */
    .pagination { display: flex; align-items: center; justify-content: center; gap: 0.48rem; margin-top: 0.9rem; flex-wrap: wrap; }
    .page-btn { padding: 0.33rem 0.88rem; border-radius: 99px; border: 1.5px solid rgba(255,255,255,0.72); background: rgba(255,255,255,0.55); color: #0d3a5a; font-family: 'Nunito', sans-serif; font-size: 0.77rem; font-weight: 800; cursor: pointer; transition: all 0.16s ease; box-shadow: 0 2px 7px rgba(60,130,200,0.09); }
    .page-btn:hover { background: rgba(255,255,255,0.82); transform: translateY(-1px); }
    .page-btn.active { background: rgba(255,255,255,0.9); border-color: rgba(80,160,240,0.45); color: #0d5a9a; }
    .page-btn:disabled { opacity: 0.35; cursor: default; transform: none; }
    .page-info { font-size: 0.74rem; font-weight: 700; color: #2a5a78; }

    /* Modal */
    .modal-overlay { display: none; position: fixed; inset: 0; z-index: 200; background: rgba(10,40,70,0.48); backdrop-filter: blur(5px); align-items: center; justify-content: center; padding: 1.5rem; }
    .modal-overlay.open { display: flex; }
    .modal-box { background: linear-gradient(150deg, rgba(255,255,255,0.95), rgba(215,242,255,0.9)); border: 2px solid rgba(255,255,255,0.95); border-radius: 20px; box-shadow: 0 18px 52px rgba(20,80,150,0.28); width: 100%; max-width: 640px; max-height: 80vh; display: flex; flex-direction: column; overflow: hidden; }
    .modal-head { display: flex; align-items: center; justify-content: space-between; padding: 0.95rem 1.3rem 0.8rem; border-bottom: 1px solid rgba(160,215,240,0.38); }
    .modal-title { font-size: 0.88rem; font-weight: 900; color: #0d2a3a; }
    .modal-close { width: 28px; height: 28px; border-radius: 50%; border: 1.5px solid rgba(160,210,235,0.55); background: rgba(255,255,255,0.72); color: #2a5a78; font-size: 0.82rem; cursor: pointer; display: flex; align-items: center; justify-content: center; font-family: 'Nunito', sans-serif; font-weight: 800; transition: all 0.14s ease; }
    .modal-close:hover { background: rgba(255,210,210,0.7); color: #7a1010; }
    .modal-body { padding: 1rem 1.3rem; overflow-y: auto; flex: 1; }
    .modal-body::-webkit-scrollbar { width: 5px; }
    .modal-body::-webkit-scrollbar-thumb { background: rgba(80,150,210,0.38); border-radius: 99px; }
    .modal-text { font-size: 0.87rem; color: #0d2030; line-height: 1.68; white-space: pre-wrap; word-break: break-word; }

    /* Settings */
    .settings-row { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem; }
    .settings-desc { font-size: 0.87rem; color: #1a4a68; line-height: 1.52; font-weight: 600; }
    .settings-desc strong { color: #0d2a3a; font-weight: 800; }

    /* Sampler sliders */
    .sampler-row { background: rgba(255,255,255,0.45); border: 1px solid rgba(200,228,245,0.55); border-radius: 12px; padding: 0.82rem 1rem; margin-bottom: 0.55rem; }
    .sampler-row-top { display: flex; align-items: center; justify-content: space-between; gap: 0.8rem; margin-bottom: 0.5rem; }
    .sampler-name { font-size: 0.82rem; font-weight: 800; color: #0d3a5a; }
    .sampler-desc { font-size: 0.67rem; font-weight: 600; color: #5a8aaa; margin-top: 2px; }
    .sampler-enable { display: flex; align-items: center; gap: 5px; cursor: pointer; flex-shrink: 0; }
    .sampler-enable input { width: 14px; height: 14px; cursor: pointer; accent-color: #1a6fa8; }
    .sampler-enable span { font-size: 0.7rem; font-weight: 800; color: #3a6a88; }
    .sampler-slider-row { display: flex; align-items: center; gap: 0.75rem; }
    .sampler-slider-row input[type=range] { flex: 1; height: 4px; cursor: pointer; accent-color: #1a6fa8; }
    .sampler-val { font-size: 0.84rem; font-weight: 800; color: #0d5a9a; min-width: 40px; text-align: right; font-family: monospace; }
    .graph-wrap { background: rgba(255,255,255,0.3); border: 1.5px solid rgba(255,255,255,0.55); border-radius: 13px; padding: 0.75rem; margin-top: 1rem; }
    #sampler-graph { width: 100%; display: block; border-radius: 7px; }
    #sampler-graph-label { text-align: center; font-size: 0.69rem; font-weight: 700; color: #5a8aaa; margin-top: 0.38rem; }
    .save-row { display: flex; justify-content: flex-end; align-items: center; gap: 0.6rem; margin-top: 1rem; }
    .save-status { font-size: 0.74rem; font-weight: 700; color: #0a6a4a; opacity: 0; transition: opacity 0.4s; }
    .model-select { padding: 0.44rem 1rem; border-radius: 99px; border: 2px solid rgba(255,255,255,0.72); background: rgba(255,255,255,0.62); color: #0d3a5a; font-family: 'Nunito', sans-serif; font-size: 0.81rem; font-weight: 700; cursor: pointer; outline: none; }

    /* Empty state */
    .empty-state { text-align: center; padding: 2.5rem 1rem; color: #4a7a9a; font-size: 0.88rem; font-weight: 700; }

    /* Regex */
    .rx-field-label { font-size: .68rem; font-weight: 800; text-transform: uppercase; letter-spacing: .7px; color: #3a6a88; margin-bottom: 4px; }
    .rx-input { background: rgba(255,255,255,0.68); border: 1.5px solid rgba(180,220,245,0.65); border-radius: 10px; padding: .42rem .75rem; font-family: 'Nunito', sans-serif; font-size: .82rem; font-weight: 600; color: #0d2a3a; outline: none; transition: border-color .15s; }
    .rx-input:focus { border-color: rgba(26,111,168,0.55); }
    textarea.rx-input { padding: .55rem .75rem; line-height: 1.52; }
    .rx-script-card { background: linear-gradient(150deg,rgba(255,255,255,.72),rgba(215,242,255,.55)); border: 1.5px solid rgba(255,255,255,.82); border-radius: 16px; padding: 1rem 1.2rem; margin-bottom: .65rem; display: flex; align-items: center; gap: 12px; box-shadow: 0 3px 10px rgba(60,130,200,.09); transition: transform .15s, box-shadow .15s; }
    .rx-script-card:hover { transform: translateY(-1px); box-shadow: 0 5px 16px rgba(60,130,200,.14); }
    .rx-script-card.disabled { opacity: .55; }
    .rx-toggle { flex-shrink: 0; width: 34px; height: 20px; background: rgba(180,210,230,.55); border-radius: 99px; border: none; cursor: pointer; position: relative; transition: background .2s; }
    .rx-toggle.on { background: linear-gradient(135deg,#1a6fa8,#0d9e8a); }
    .rx-toggle::after { content: ''; position: absolute; top: 3px; left: 3px; width: 14px; height: 14px; border-radius: 50%; background: #fff; transition: transform .2s; box-shadow: 0 1px 4px rgba(0,0,0,.2); }
    .rx-toggle.on::after { transform: translateX(14px); }
    .rx-script-info { flex: 1; min-width: 0; }
    .rx-script-name { font-size: .85rem; font-weight: 800; color: #0d2a3a; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .rx-script-meta { font-size: .7rem; font-weight: 600; color: #5a8aaa; margin-top: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .rx-script-meta code { font-family: monospace; background: rgba(100,160,220,.12); border-radius: 4px; padding: 1px 5px; }
    .rx-edit-btn { flex-shrink: 0; font-size: .72rem; font-weight: 800; color: #0d5a9a; background: rgba(60,140,240,.1); border: 1px solid rgba(60,140,240,.28); border-radius: 99px; padding: 4px 12px; cursor: pointer; font-family: 'Nunito', sans-serif; transition: background .15s; }
    .rx-edit-btn:hover { background: rgba(60,140,240,.2); }

    /* Health chips */
    .health-meta { display: flex; gap: 1.5rem; flex-wrap: wrap; margin-bottom: 1rem; }
    .health-meta-item { display: flex; flex-direction: column; gap: 2px; }
    .health-meta-label { font-size: .68rem; font-weight: 800; text-transform: uppercase; letter-spacing: .7px; color: #3a6a88; }
    .health-meta-value { font-size: 1.1rem; font-weight: 900; color: #0d5a9a; }
    .ext-chip { display: inline-flex; align-items: center; gap: 6px; background: rgba(255,255,255,.55); border: 1.5px solid rgba(200,228,245,.65); border-radius: 12px; padding: .45rem .8rem; margin: .3rem .3rem 0 0; }
    .ext-chip-name    { font-size: .8rem;  font-weight: 800; color: #0d2a3a; }
    .ext-chip-version { font-size: .68rem; font-weight: 700; color: #5a8aaa; }
    .ext-chip-hooks   { font-size: .65rem; font-weight: 700; color: #3a7090; background: rgba(100,180,240,.12); border-radius: 99px; padding: 2px 7px; }
    .ext-chip-priority{ font-size: .65rem; font-weight: 700; color: #8a6aaa; background: rgba(140,100,240,.1); border-radius: 99px; padding: 2px 7px; }

    /* RAG sliders */
    .rag-slider-row { background: rgba(255,255,255,0.45); border: 1px solid rgba(200,228,245,0.55); border-radius: 12px; padding: 0.82rem 1rem; margin-bottom: 0.55rem; }
    .rag-slider-top { display: flex; align-items: center; justify-content: space-between; gap: 0.8rem; margin-bottom: 0.45rem; }
    .rag-slider-name { font-size: 0.82rem; font-weight: 800; color: #0d3a5a; }
    .rag-slider-desc { font-size: 0.67rem; font-weight: 600; color: #5a8aaa; margin-top: 2px; }
    .rag-slider-inner { display: flex; align-items: center; gap: 0.75rem; }
    .rag-slider-inner input[type=range] { flex: 1; height: 4px; cursor: pointer; accent-color: #0d9e8a; }
    .rag-slider-val { font-size: 0.84rem; font-weight: 800; color: #0d5a9a; min-width: 48px; text-align: right; font-family: monospace; }

    /* TunnelVision */
    .tv-tree-card { background: linear-gradient(150deg, rgba(255,255,255,0.72), rgba(230,215,255,0.45)); border: 1.5px solid rgba(255,255,255,0.82); border-radius: 16px; padding: 1rem 1.2rem; margin-bottom: 0.65rem; box-shadow: 0 3px 10px rgba(100,60,200,0.09); transition: transform 0.15s, box-shadow 0.15s; }
    .tv-tree-card:hover { transform: translateY(-1px); box-shadow: 0 5px 16px rgba(100,60,200,0.14); }
    .tv-tree-header { display: flex; align-items: center; gap: 10px; margin-bottom: 0.5rem; }
    .tv-tree-name { font-size: 0.88rem; font-weight: 800; color: #0d2a3a; flex: 1; }
    .tv-tree-active { font-size: 0.62rem; font-weight: 900; background: rgba(100,60,220,0.15); border: 1px solid rgba(100,60,220,0.35); color: #4a0a8a; border-radius: 99px; padding: 2px 8px; }
    .tv-tree-meta { font-size: 0.72rem; font-weight: 600; color: #5a8aaa; display: flex; gap: 1rem; flex-wrap: wrap; }
    .tv-tree-meta span { display: flex; align-items: center; gap: 4px; }
    .tv-node-row { background: rgba(255,255,255,0.5); border: 1px solid rgba(200,215,245,0.5); border-radius: 10px; padding: 0.6rem 0.85rem; margin-bottom: 0.4rem; }
    .tv-node-header { display: flex; align-items: center; gap: 8px; cursor: pointer; }
    .tv-node-icon { font-size: 0.8rem; flex-shrink: 0; }
    .tv-node-label { font-size: 0.82rem; font-weight: 800; color: #0d2a3a; flex: 1; }
    .tv-node-count { font-size: 0.65rem; font-weight: 700; color: #5a8aaa; background: rgba(100,150,220,0.12); border-radius: 99px; padding: 2px 7px; }
    .tv-node-toggle { font-size: 0.6rem; color: #8aaaaa; transition: transform 0.2s; }
    .tv-node-row.expanded .tv-node-toggle { transform: rotate(90deg); }
    .tv-node-entries { display: none; margin-top: 0.5rem; padding-top: 0.5rem; border-top: 1px solid rgba(180,210,240,0.3); }
    .tv-node-row.expanded .tv-node-entries { display: block; }
    .tv-entry-row { display: flex; align-items: flex-start; gap: 8px; padding: 0.45rem 0.5rem; border-radius: 8px; margin-bottom: 0.3rem; background: rgba(255,255,255,0.45); border: 1px solid rgba(200,220,245,0.4); }
    .tv-entry-uid { font-size: 0.62rem; font-weight: 800; color: #8a6aaa; background: rgba(140,100,240,0.1); border-radius: 99px; padding: 1px 6px; flex-shrink: 0; margin-top: 1px; }
    .tv-entry-info { flex: 1; min-width: 0; }
    .tv-entry-title { font-size: 0.78rem; font-weight: 800; color: #0d2a3a; }
    .tv-entry-content { font-size: 0.71rem; color: #3a5a78; margin-top: 2px; line-height: 1.45; white-space: pre-wrap; word-break: break-word; }
    .tv-entry-keys { display: flex; gap: 4px; flex-wrap: wrap; margin-top: 4px; }
    .tv-entry-key { font-size: 0.6rem; font-weight: 700; background: rgba(60,140,240,0.1); border: 1px solid rgba(60,140,240,0.25); color: #0d3a8a; border-radius: 99px; padding: 1px 6px; }
    .tv-entry-disabled { opacity: 0.4; }
    .tv-input { background: rgba(255,255,255,0.68); border: 1.5px solid rgba(180,220,245,0.65); border-radius: 10px; padding: 0.42rem 0.75rem; font-family: 'Nunito', sans-serif; font-size: 0.82rem; font-weight: 600; color: #0d2a3a; outline: none; transition: border-color 0.15s; width: 100%; }
    .tv-input:focus { border-color: rgba(100,60,220,0.45); }
    textarea.tv-input { padding: 0.55rem 0.75rem; line-height: 1.52; resize: vertical; }
    .tv-field-label { font-size: 0.68rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.7px; color: #5a4a8a; margin-bottom: 4px; }
    .tv-summary { font-size: 0.72rem; color: #5a6a8a; font-style: italic; margin-top: 3px; }

    @media (max-width: 600px) {
      .header-title { font-size: 1.55rem; }
      .stats-grid { grid-template-columns: repeat(2, 1fr); }
    }
  </style>
</head>
<body>
<canvas id="bg-canvas"></canvas>

<!-- Message modal -->
<div class="modal-overlay" id="msg-modal" onclick="closeModal(event)">
  <div class="modal-box">
    <div class="modal-head">
      <span class="modal-title" id="modal-title">Message</span>
      <button class="modal-close" onclick="closeModalDirect()">✕</button>
    </div>
    <div class="modal-body"><div class="modal-text" id="modal-text"></div></div>
  </div>
</div>

<!-- Script editor modal -->
<div class="modal-overlay" id="script-modal" onclick="closeScriptModal(event)">
  <div class="modal-box" style="max-width:520px;">
    <div class="modal-head">
      <span class="modal-title" id="script-modal-title">New Script</span>
      <button class="modal-close" onclick="closeScriptModalDirect()">✕</button>
    </div>
    <div class="modal-body" style="display:flex;flex-direction:column;gap:12px;padding:1.2rem 1.3rem;">
      <div><div class="rx-field-label">Description</div><input id="sm-desc" type="text" class="rx-input" style="width:100%;" placeholder="What does this script do?"></div>
      <div><div class="rx-field-label">Find (regex pattern)</div><input id="sm-find" type="text" class="rx-input" style="width:100%;" placeholder="e\.g\. \*([^*]+)\*"></div>
      <div><div class="rx-field-label">Replace string</div><input id="sm-replace" type="text" class="rx-input" style="width:100%;" placeholder='e.g. _$1_ or {{match}}'></div>
      <div style="display:flex;gap:16px;align-items:center;">
        <div><div class="rx-field-label">Flags</div><input id="sm-flags" type="text" class="rx-input" value="g" style="width:64px;"></div>
        <label style="display:flex;align-items:center;gap:7px;font-size:.8rem;font-weight:700;color:#3a6a88;margin-top:14px;cursor:pointer;"><input id="sm-trim" type="checkbox"> trimStrings</label>
        <label style="display:flex;align-items:center;gap:7px;font-size:.8rem;font-weight:700;color:#3a6a88;margin-top:14px;cursor:pointer;"><input id="sm-enabled" type="checkbox" checked> Enabled</label>
      </div>
      <div id="sm-error" style="display:none;font-size:.76rem;font-weight:700;color:#7a1010;background:rgba(220,60,60,0.1);border:1px solid rgba(220,60,60,0.3);border-radius:8px;padding:6px 10px;"></div>
      <div style="display:flex;justify-content:flex-end;gap:8px;margin-top:4px;">
        <button class="btn danger" id="sm-delete-btn" onclick="deleteScriptFromModal()" style="display:none;">✕ Delete</button>
        <button class="btn" onclick="closeScriptModalDirect()">Cancel</button>
        <button class="btn primary" onclick="saveScriptModal()">💾 Save</button>
      </div>
    </div>
  </div>
</div>

<!-- TunnelVision Add Entry modal -->
<div class="modal-overlay" id="tv-entry-modal" onclick="closeTvEntryModal(event)">
  <div class="modal-box" style="max-width:540px;">
    <div class="modal-head">
      <span class="modal-title" id="tv-entry-modal-title">Add Entry</span>
      <button class="modal-close" onclick="closeTvEntryModalDirect()">✕</button>
    </div>
    <div class="modal-body" style="display:flex;flex-direction:column;gap:12px;padding:1.2rem 1.3rem;">
      <div><div class="tv-field-label">Title</div><input id="tv-em-title" type="text" class="tv-input" placeholder="e.g. Vincent — Personality & Background"></div>
      <div><div class="tv-field-label">Content</div><textarea id="tv-em-content" class="tv-input" rows="5" placeholder="Write in third-person, factual style..."></textarea></div>
      <div><div class="tv-field-label">Keywords (comma separated)</div><input id="tv-em-keys" type="text" class="tv-input" placeholder="vincent, character, personality"></div>
      <div id="tv-em-error" style="display:none;font-size:.76rem;font-weight:700;color:#7a1010;background:rgba(220,60,60,0.1);border:1px solid rgba(220,60,60,0.3);border-radius:8px;padding:6px 10px;"></div>
      <div style="display:flex;justify-content:flex-end;gap:8px;margin-top:4px;">
        <button class="btn" onclick="closeTvEntryModalDirect()">Cancel</button>
        <button class="btn primary" onclick="saveTvEntry()">💾 Save Entry</button>
      </div>
    </div>
  </div>
</div>

<!-- TunnelVision Add Node modal -->
<div class="modal-overlay" id="tv-node-modal" onclick="closeTvNodeModal(event)">
  <div class="modal-box" style="max-width:420px;">
    <div class="modal-head">
      <span class="modal-title">Add Channel</span>
      <button class="modal-close" onclick="closeTvNodeModalDirect()">✕</button>
    </div>
    <div class="modal-body" style="display:flex;flex-direction:column;gap:12px;padding:1.2rem 1.3rem;">
      <div><div class="tv-field-label">Channel Name</div><input id="tv-nm-label" type="text" class="tv-input" placeholder="e.g. Characters, Locations, World Rules"></div>
      <div><div class="tv-field-label">Summary (optional)</div><input id="tv-nm-summary" type="text" class="tv-input" placeholder="What does this channel contain?"></div>
      <div id="tv-nm-error" style="display:none;font-size:.76rem;font-weight:700;color:#7a1010;background:rgba(220,60,60,0.1);border:1px solid rgba(220,60,60,0.3);border-radius:8px;padding:6px 10px;"></div>
      <div style="display:flex;justify-content:flex-end;gap:8px;margin-top:4px;">
        <button class="btn" onclick="closeTvNodeModalDirect()">Cancel</button>
        <button class="btn primary" onclick="saveTvNode()">📺 Add Channel</button>
      </div>
    </div>
  </div>
</div>

<div class="page">

  <!-- Header -->
  <div class="header">
    <div class="header-glass">
      <div class="header-title">✦ Blank's Roleplay Proxy ✦</div>
      <div class="header-sub">Powered by OpenRouter · Claude · Kiana Designs</div>
      <div>
        <span class="status-clock" id="status-badge">
          <span class="status-dot"></span>
          <span id="status-text">Online</span>
          <span class="status-divider"></span>
          <span class="clock-text" id="clock-text">--:-- -- · --- --</span>
        </span>
      </div>
    </div>
  </div>

  <!-- Tabs -->
  <div class="tabs">
    <button class="tab-btn active" onclick="switchTab('overview',this)">✦ Overview</button>
    <button class="tab-btn" onclick="switchTab('logs',this)">📋 Logs</button>
    <button class="tab-btn" onclick="switchTab('settings',this)">⚙ Settings</button>
  </div>

  <!-- ══ OVERVIEW TAB ══ -->
  <div class="tab-panel active" id="tab-overview">
    <div class="stats-grid">
      <div class="stat-card"><span class="stat-icon">📨</span><div class="stat-label">Requests Today</div><div class="stat-value" id="stat-requests">—</div><div class="stat-sub">messages sent</div></div>
      <div class="stat-card"><span class="stat-icon">🔤</span><div class="stat-label">Total Tokens</div><div class="stat-value" id="stat-tokens">—</div><div class="stat-sub">prompt + completion</div></div>
      <div class="stat-card"><span class="stat-icon">⚡</span><div class="stat-label">Cache Hit Rate</div><div class="stat-value" id="stat-cache">—</div><div class="stat-sub">of requests cached</div></div>
      <div class="stat-card"><span class="stat-icon">📊</span><div class="stat-label">Avg Tokens/Msg</div><div class="stat-value" id="stat-avg">—</div><div class="stat-sub">per request</div></div>
      <div class="stat-card"><span class="stat-icon">💰</span><div class="stat-label">Est. Cost Today</div><div class="stat-value" id="stat-cost">—</div><div class="stat-sub">USD (approx)</div></div>
      <div class="stat-card"><span class="stat-icon">✨</span><div class="stat-label">Tokens Saved</div><div class="stat-value" id="stat-saved">—</div><div class="stat-sub">via cache hits</div></div>
    </div>
    <div class="glass-card">
      <div class="card-title">System</div>
      <div class="health-meta">
        <div class="health-meta-item"><span class="health-meta-label">Uptime</span><span class="health-meta-value" id="health-uptime">—</span></div>
        <div class="health-meta-item"><span class="health-meta-label">Last Request</span><span class="health-meta-value" style="font-size:.85rem;color:#1a4a68;" id="health-last">—</span></div>
      </div>
      <div class="card-title" style="margin-bottom:.6rem;">Extensions</div>
      <div id="health-extensions"><div class="empty-state" style="padding:.5rem 0;">Loading…</div></div>
    </div>
  </div>

  <!-- ══ LOGS TAB ══ -->
  <div class="tab-panel" id="tab-logs">
    <div class="glass-card">
      <div class="log-controls">
        <button class="btn" onclick="fetchLogs()">↻ Refresh</button>
        <button class="btn danger" onclick="clearLogs()">✕ Clear</button>
        <span class="log-count" id="log-count"></span>
      </div>
      <div class="filter-row">
        <span class="filter-pill filter-user active"   onclick="toggleFilter('user',this)">👤 User</span>
        <span class="filter-pill filter-bot active"    onclick="toggleFilter('bot',this)">✦ Bot</span>
        <span class="filter-pill filter-system active" onclick="toggleFilter('system',this)">⚙ System</span>
        <span class="filter-pill filter-error active"  onclick="toggleFilter('error',this)">✗ Error</span>
      </div>
      <div id="log-list"><div class="empty-state">Loading logs…</div></div>
      <div class="pagination" id="pagination"></div>
    </div>
  </div>

  <!-- ══ SETTINGS TAB ══ -->
  <div class="tab-panel" id="tab-settings">

    <!-- Proxy controls -->
    <div class="glass-card">
      <div class="card-title">Proxy Controls</div>
      <div class="settings-row">
        <div class="settings-desc"><strong>Restart Proxy</strong><br>Restarts the Node.js process. Docker will automatically bring it back online.</div>
        <button class="btn danger" onclick="restartProxy()">⟳ Restart Proxy</button>
      </div>
    </div>

    <!-- Sampler settings -->
    <div class="glass-card">
      <div class="card-title">Sampler Settings</div>
      <div class="settings-row" style="margin-bottom:1.1rem;">
        <div class="settings-desc"><strong>Target Model</strong><br>Claude only supports Top P and Top K via OpenRouter.</div>
        <select class="model-select" id="sampler-model" onchange="fetchSamplers()">
          <option value="anthropic/claude-sonnet-4-5">Claude Sonnet 4.5</option>
          <option value="anthropic/claude-opus-4-5">Claude Opus 4.5</option>
          <option value="openai/gpt-4o">GPT-4o</option>
          <option value="openai/gpt-4o-mini">GPT-4o Mini</option>
          <option value="other">Other Model</option>
        </select>
      </div>
      <div id="sampler-sliders"><div class="empty-state" style="padding:1rem 0;">Loading samplers…</div></div>
      <div class="graph-wrap">
        <canvas id="sampler-graph" height="110"></canvas>
        <div id="sampler-graph-label">Token probability distribution</div>
      </div>
      <div class="save-row">
        <span class="save-status" id="save-status">✓ Saved!</span>
        <button class="btn success" onclick="saveSamplers()">💾 Save Settings</button>
      </div>
    </div>

    <!-- Regex scripts -->
    <div class="glass-card">
      <div class="card-title" style="margin-bottom:0.8rem;">Regex Scripts</div>
      <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:1rem;">
        <input type="file" id="regex-import-input" accept=".json" style="display:none" onchange="regexImportHandle(event)">
        <button class="btn" onclick="document.getElementById('regex-import-input').click()">⬆ Import JSON</button>
        <button class="btn" onclick="regexExport()">⬇ Export JSON</button>
        <button class="btn primary" onclick="openScriptModal(null)">+ New Script</button>
      </div>
      <div id="regex-script-list"><div class="empty-state" style="padding:1.5rem 0;">Loading scripts…</div></div>
    </div>

    <!-- Regex live test -->
    <div class="glass-card">
      <div class="card-title">Regex Live Test</div>
      <div class="settings-desc" style="margin-bottom:10px;">Runs all enabled scripts against the input in order.</div>
      <div class="rx-field-label">Input text</div>
      <textarea id="test-input" class="rx-input" rows="5" style="width:100%;resize:vertical;margin-bottom:10px;" placeholder="Paste sample AI output here…"></textarea>
      <button class="btn primary" onclick="runTest()">▶ Run All Scripts</button>
      <div class="rx-field-label" style="margin-top:12px;">Output</div>
      <textarea id="test-output" class="rx-input" rows="5" style="width:100%;resize:vertical;opacity:.88;" readonly></textarea>
    </div>

    <!-- RAG Memory -->
    <div class="glass-card">
      <div class="card-title">RAG Memory</div>
      <div class="settings-row" style="margin-bottom:1.2rem;">
        <div class="settings-desc"><strong>Semantic Memory</strong><br>Retrieves relevant past turns from Qdrant and injects them into context before each generation.</div>
        <button class="btn" id="rag-toggle-btn" onclick="ragToggle()">Loading…</button>
      </div>
      <div class="settings-row" style="margin-bottom:1.2rem;">
        <div class="settings-desc"><strong>Protect Next Turn</strong><br>Marks the next response as temporally blind — immune to decay, always retrieved at full score.</div>
        <button class="btn" id="rag-blind-btn" onclick="ragBlindNext()" style="background:rgba(140,100,240,0.16);border-color:rgba(140,100,240,0.4);color:#4a0a8a;">🔒 Protect Next Turn</button>
      </div>
      <div class="health-meta">
        <div class="health-meta-item"><span class="health-meta-label">Last Character</span><span class="health-meta-value" id="rag-stat-char">—</span></div>
        <div class="health-meta-item"><span class="health-meta-label">Chars Injected</span><span class="health-meta-value" id="rag-stat-chars">—</span></div>
        <div class="health-meta-item"><span class="health-meta-label">At Msg #</span><span class="health-meta-value" id="rag-stat-msg">—</span></div>
        <div class="health-meta-item"><span class="health-meta-label">Total Injections</span><span class="health-meta-value" id="rag-stat-total">—</span></div>
        <div class="health-meta-item"><span class="health-meta-label">Total Indexed</span><span class="health-meta-value" id="rag-stat-indexed">—</span></div>
      </div>
    </div>

    <!-- RAG collections -->
    <div class="glass-card">
      <div class="card-title" style="margin-bottom:0.8rem;">RAG Collections</div>
      <div id="rag-collections"><div class="empty-state">Loading…</div></div>
      <div style="margin-top:0.6rem;"><button class="btn" onclick="fetchRagCollections()" style="font-size:0.76rem;">↻ Refresh</button></div>
    </div>

    <!-- RAG config sliders -->
    <div class="glass-card">
      <div class="card-title">RAG Config</div>
      <div id="rag-config-sliders"><div class="empty-state" style="padding:1rem 0;">Loading…</div></div>
      <div class="save-row">
        <span class="save-status" id="rag-save-status">✓ Saved!</span>
        <button class="btn success" onclick="ragSaveConfig()">💾 Save Config</button>
      </div>
    </div>

    <!-- ══ TUNNELVISION ══ -->
    <div class="glass-card" style="border-color:rgba(180,160,255,0.5);">
      <div class="card-title" style="color:#5a3a9a;">📺 TunnelVision — Lorebook Memory</div>
      <div class="settings-row" style="margin-bottom:1.2rem;">
        <div class="settings-desc">
          <strong>Auto-Summary</strong><br>
          Automatically forces Claude to summarize every N messages. Keeps a running history of events in the Summaries channel.
        </div>
        <button class="btn" id="tv-autosummary-btn" onclick="tvToggleAutoSummary()">Loading…</button>
      </div>
      <div id="tv-autosummary-options" style="display:none;margin-bottom:1.2rem;">
        <div class="rag-slider-row">
          <div class="rag-slider-top">
            <div>
              <div class="rag-slider-name">Summary Interval</div>
              <div class="rag-slider-desc">Summarize every N messages (user + bot combined)</div>
            </div>
          </div>
          <div class="rag-slider-inner">
            <input type="range" id="tv-summary-interval" min="10" max="100" step="5" value="20" oninput="document.getElementById('tv-summary-interval-val').textContent=this.value">
            <span class="rag-slider-val" id="tv-summary-interval-val">20</span>
          </div>
        </div>
        <div style="display:flex;justify-content:flex-end;margin-top:0.5rem;">
          <button class="btn success" onclick="tvSaveAutoSummary()">💾 Save</button>
        </div>
      </div>
      <div class="settings-row" style="margin-bottom:1.2rem;">
        <div class="settings-desc">
          <strong>Mandatory Tools</strong><br>
          Forces Claude to call at least one TunnelVision tool every turn. Ensures Search fires even when Claude would otherwise skip it.
        </div>
        <button class="btn" id="tv-mandatory-btn" onclick="tvToggleMandatory()">Loading…</button>
      </div>
      <div class="settings-row" style="margin-bottom:1.2rem;">
        <div class="settings-desc">
          <strong>Active Tree</strong><br>
          Auto-detected from the bot's persona tag. Override manually if needed.
        </div>
        <div style="display:flex;gap:8px;align-items:center;">
          <input id="tv-active-tree-input" type="text" class="tv-input" style="width:160px;" placeholder="auto-detect">
          <button class="btn primary" onclick="tvSetActiveTree()">Set</button>
          <button class="btn" onclick="tvClearActiveTree()">Clear</button>
        </div>
      </div>
      <div class="health-meta">
        <div class="health-meta-item"><span class="health-meta-label">Active Tree</span><span class="health-meta-value" style="font-size:0.9rem;" id="tv-stat-active">—</span></div>
        <div class="health-meta-item"><span class="health-meta-label">Nodes</span><span class="health-meta-value" id="tv-stat-nodes">—</span></div>
        <div class="health-meta-item"><span class="health-meta-label">Entries</span><span class="health-meta-value" id="tv-stat-entries">—</span></div>
        <div class="health-meta-item"><span class="health-meta-label">Trees on Disk</span><span class="health-meta-value" id="tv-stat-trees">—</span></div>
      </div>
    </div>

    <!-- TunnelVision Trees -->
    <div class="glass-card" style="border-color:rgba(180,160,255,0.4);">
      <div class="card-title" style="color:#5a3a9a;margin-bottom:0.8rem;">📺 Trees</div>
      <div style="display:flex;gap:8px;margin-bottom:1rem;flex-wrap:wrap;">
        <button class="btn" onclick="fetchTvStatus();fetchTvTrees();" style="font-size:0.76rem;">↻ Refresh</button>
      </div>
      <div id="tv-trees-list"><div class="empty-state">Loading…</div></div>
    </div>

    <!-- TunnelVision Tree Editor -->
    <div class="glass-card" id="tv-editor-card" style="border-color:rgba(180,160,255,0.4);display:none;">
      <div class="card-title" style="color:#5a3a9a;margin-bottom:0.8rem;">
        📺 Tree Editor — <span id="tv-editor-name">—</span>
      </div>
      <div style="display:flex;gap:8px;margin-bottom:1rem;flex-wrap:wrap;">
        <button class="btn primary" onclick="openTvNodeModal()">+ Add Channel</button>
        <button class="btn" onclick="fetchTvTree(_tvEditorName)">↻ Refresh</button>
        <button class="btn danger" onclick="tvDeleteTree(_tvEditorName)">✕ Delete Tree</button>
      </div>
      <div id="tv-tree-nodes"><div class="empty-state">Select a tree to edit.</div></div>
    </div>

  </div><!-- /#tab-settings -->
</div><!-- /.page -->

<script>
// ── Bubble background ──────────────────────────────────
(function() {
  const canvas = document.getElementById('bg-canvas');
  const ctx = canvas.getContext('2d');
  let W, H, bubbles = [];
  function resize() { W = canvas.width = window.innerWidth; H = canvas.height = window.innerHeight; }
  function spawn() {
    const r = 18 + Math.random() * 55;
    bubbles.push({ x: Math.random()*W, y: H+r, r, speed: 0.22+Math.random()*0.42, drift: (Math.random()-0.5)*0.32, alpha: 0.1+Math.random()*0.2, wobble: Math.random()*Math.PI*2, ws: 0.018+Math.random()*0.018 });
  }
  function draw(b) {
    const g = ctx.createRadialGradient(b.x-b.r*.3, b.y-b.r*.3, b.r*.05, b.x, b.y, b.r);
    g.addColorStop(0,   `rgba(255,255,255,${b.alpha*2.2})`);
    g.addColorStop(0.35,`rgba(210,240,255,${b.alpha*.9})`);
    g.addColorStop(0.75,`rgba(150,210,240,${b.alpha*.3})`);
    g.addColorStop(1,   'rgba(100,180,220,0)');
    ctx.beginPath(); ctx.arc(b.x,b.y,b.r,0,Math.PI*2); ctx.fillStyle=g; ctx.fill();
    ctx.beginPath(); ctx.arc(b.x,b.y,b.r,0,Math.PI*2);
    ctx.strokeStyle=`rgba(255,255,255,${b.alpha*1.7})`; ctx.lineWidth=1.1; ctx.stroke();
    ctx.beginPath(); ctx.ellipse(b.x-b.r*.28,b.y-b.r*.3,b.r*.27,b.r*.13,-0.5,0,Math.PI*2);
    ctx.fillStyle=`rgba(255,255,255,${b.alpha*2.4})`; ctx.fill();
  }
  function animate() {
    ctx.clearRect(0,0,W,H);
    bubbles.forEach(b => { b.wobble+=b.ws; b.y-=b.speed; b.x+=b.drift+Math.sin(b.wobble)*.28; draw(b); });
    bubbles = bubbles.filter(b => b.y+b.r>0);
    if (Math.random()<0.016) spawn();
    requestAnimationFrame(animate);
  }
  resize(); window.addEventListener('resize', resize);
  for (let i=0;i<10;i++) { spawn(); bubbles[i].y=Math.random()*H; }
  animate();
})();

// ── Clock ──────────────────────────────────────────────
function updateClock() {
  const now = new Date();
  const parts = new Intl.DateTimeFormat('en-US', { timeZone:'America/New_York', hour:'numeric', minute:'2-digit', hour12:true, weekday:'short', month:'short', day:'numeric' }).formatToParts(now);
  const get = t => parts.find(p=>p.type===t)?.value||'';
  document.getElementById('clock-text').textContent = `${get('hour')}:${get('minute')} ${get('dayPeriod')} · ${get('weekday')} ${get('month')} ${get('day')}`;
}
updateClock(); setInterval(updateClock, 1000);

// ── Tab switching ──────────────────────────────────────
function switchTab(name, btn) {
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('tab-' + name).classList.add('active');
  btn.classList.add('active');
  if (name === 'logs')     fetchLogs();
  if (name === 'overview') { fetchStats(); fetchHealth(); }
  if (name === 'settings') { fetchSamplers(); fetchRegexScripts(); fetchRagStatus(); fetchRagCollections(); fetchTvStatus(); fetchTvTrees(); }
}

// ── Stats ──────────────────────────────────────────────
async function fetchStats() {
  try {
    const data = await fetch('/dashboard/logs').then(r=>r.json());
    const logs = (data.logs||[]).map(l=>{try{const p=JSON.parse(l);return typeof p==='object'&&p?p:null;}catch{return null;}}).filter(Boolean);
    const today = new Date().toDateString();
    const bot = logs.filter(l=>(l.event==='bot'||l.event==='success')&&new Date(l.timestamp).toDateString()===today);
    const req = logs.filter(l=>(l.event==='user'||l.event==='request')&&new Date(l.timestamp).toDateString()===today);
    const tot = bot.reduce((s,l)=>s+(l.total_tokens||0),0);
    const hits = bot.filter(l=>l.cache_read>0).length;
    const fmt = n => n>1000?(n/1000).toFixed(1)+'k':String(n||0);
    document.getElementById('stat-requests').textContent = req.length||'0';
    document.getElementById('stat-tokens').textContent   = fmt(tot);
    document.getElementById('stat-cache').textContent    = bot.length?Math.round(hits/bot.length*100)+'%':'0%';
    document.getElementById('stat-avg').textContent      = fmt(bot.length?Math.round(tot/bot.length):0);
    document.getElementById('stat-cost').textContent     = '$'+((tot/1e6)*3).toFixed(3);
    document.getElementById('stat-saved').textContent    = fmt(bot.reduce((s,l)=>s+(l.cache_read||0),0));
  } catch(e) { console.error('Stats:',e); }
}

// ── Health ─────────────────────────────────────────────
function formatUptime(s) { const h=Math.floor(s/3600), m=Math.floor((s%3600)/60), sec=s%60; if(h>0)return`${h}h ${m}m`; if(m>0)return`${m}m ${sec}s`; return`${sec}s`; }
async function fetchHealth() {
  try {
    const data = await fetch('/health').then(r => r.json());
    document.getElementById('health-uptime').textContent = formatUptime(data.uptime ?? 0);
    document.getElementById('health-last').textContent = data.lastRequest ? new Date(data.lastRequest).toLocaleTimeString([],{hour:'2-digit',minute:'2-digit',second:'2-digit'}) : 'None yet';
    const el = document.getElementById('health-extensions');
    if (!data.extensions?.length) { el.innerHTML = '<div class="empty-state" style="padding:.5rem 0;">No extensions loaded.</div>'; return; }
    el.innerHTML = data.extensions.map(e => `<div class="ext-chip"><span class="ext-chip-name">${esc(e.name)}</span><span class="ext-chip-version">v${esc(String(e.version))}</span><span class="ext-chip-priority">p${e.priority}</span><span class="ext-chip-hooks">${e.hooks.join(', ')}</span></div>`).join('');
  } catch(e) { console.error('Health:', e); }
}

// ── Logs ──────────────────────────────────────────────
const activeFilters = new Set(['user','bot','system','error']);
let allLogs=[], curPage=1, msgStore={};
const PAGE=10;

function toggleFilter(type,el) { activeFilters.has(type)?activeFilters.delete(type):activeFilters.add(type); el.classList.toggle('active'); renderLogs(); }

async function fetchLogs() {
  try {
    const data = await fetch('/dashboard/logs').then(r=>r.json());
    allLogs = (data.logs||[]).map((l,i)=>({raw:l,idx:i,obj:tryParse(l)})).reverse();
    document.getElementById('log-count').textContent = (data.logs||[]).length+' entries';
    curPage=1; renderLogs();
  } catch { document.getElementById('log-list').innerHTML='<div class="empty-state">Failed to load logs.</div>'; }
}

function renderLogs() {
  const list=document.getElementById('log-list'), pgDiv=document.getElementById('pagination');
  const vis=allLogs.filter(({obj})=>activeFilters.has(getType(obj)));
  if (!vis.length) { list.innerHTML='<div class="empty-state">No logs match filters.</div>'; pgDiv.innerHTML=''; return; }
  const total=Math.ceil(vis.length/PAGE);
  if (curPage>total) curPage=total;
  const start=(curPage-1)*PAGE;
  list.innerHTML='';
  vis.slice(start,start+PAGE).forEach(({obj,raw,idx})=>list.appendChild(makeEntry(obj,raw,idx)));
  pgDiv.innerHTML='';
  pgDiv.appendChild(mkPageBtn('← Prev',curPage===1,()=>{curPage--;renderLogs();}));
  for (let p=Math.max(1,curPage-2);p<=Math.min(total,curPage+2);p++) {
    const b=mkPageBtn(p,false,(()=>{const _p=p;return()=>{curPage=_p;renderLogs();};})()); if(p===curPage)b.classList.add('active'); pgDiv.appendChild(b);
  }
  const info=document.createElement('span'); info.className='page-info'; info.textContent=`${start+1}–${Math.min(start+PAGE,vis.length)} of ${vis.length}`; pgDiv.appendChild(info);
  pgDiv.appendChild(mkPageBtn('Next →',curPage===total,()=>{curPage++;renderLogs();}));
}

function mkPageBtn(label,disabled,fn) { const b=document.createElement('button'); b.className='page-btn'; b.textContent=label; b.disabled=disabled; b.onclick=fn; return b; }
function getType(obj) { if(!obj)return'system'; if(obj.event==='user'||obj.event==='request')return'user'; if(obj.event==='bot'||obj.event==='success')return'bot'; if(obj.event==='error')return'error'; return'system'; }
function tryParse(str) { try{const p=JSON.parse(str);return typeof p==='object'&&p?p:null;}catch{return null;} }

function makeEntry(obj,raw,idx) {
  const el=document.createElement('div'), type=getType(obj);
  el.className=`log-entry type-${type}`; el.id='log-'+idx;
  const time=obj?.timestamp?new Date(obj.timestamp).toLocaleTimeString([],{hour:'2-digit',minute:'2-digit',second:'2-digit'}):'--:--:--';
  const labels={user:'👤 User',bot:'✦ Bot',error:'✗ Err',system:'⚙ Sys'};
  const cached=obj?.cache_read>0;
  let summary='';
  if(type==='user')   summary=obj.user?obj.user.slice(0,80):`${obj.messages||0} messages`;
  if(type==='bot')    summary=obj.char?obj.char.slice(0,80):`${obj.total_tokens||0} tokens`;
  if(type==='error')  summary=obj.error?.message||String(obj.error||'Error');
  if(type==='system') summary=obj.message||raw;
  el.innerHTML=`
    <div class="log-header" onclick="toggleEntry('log-${idx}')">
      <span class="log-pill pill-${type}">${labels[type]}</span>
      <span class="log-time">${time}</span>
      <span class="log-summary">${esc(summary)}</span>
      ${cached?'<span class="log-cached">✦ cached</span>':''}
      <span class="log-chevron">▶</span>
    </div>
    <div class="log-detail">${makeDetail(obj,type,idx)}</div>`;
  return el;
}

function makeDetail(obj,type,idx) {
  if(!obj)return'';
  if(type==='system')return`<div class="sys-msg">${esc(obj.message||'')}</div>`;
  const fields=[['Model',obj.model?.replace('anthropic/','').replace('openai/','')],['Prompt',obj.prompt_tokens],['Completion',obj.completion_tokens],['Total',obj.total_tokens],['Cache',obj.cache_read],['Msgs',obj.messages]];
  const chips=fields.filter(([,v])=>v!=null).map(([l,v])=>`<div class="detail-chip"><div class="chip-label">${l}</div><div class="chip-value">${esc(String(v))}</div></div>`).join('');
  let msgs='';
  if(obj.user){const k=`u${idx}`;msgStore[k]=obj.user;msgs+=`<div class="msg-block"><span class="msg-label user">👤 User</span><span class="msg-preview">${esc(obj.user.slice(0,80))}${obj.user.length>80?'…':''}</span><button class="msg-btn" onclick="openModal('👤 User Message','${k}')">View</button></div>`;}
  if(obj.char){const k=`c${idx}`;msgStore[k]=obj.char;msgs+=`<div class="msg-block"><span class="msg-label bot">✦ Char</span><span class="msg-preview">${esc(obj.char.slice(0,80))}${obj.char.length>80?'…':''}</span><button class="msg-btn" onclick="openModal('✦ Character Reply','${k}')">View</button></div>`;}
  return`<div class="detail-grid">${chips}</div>${msgs}`;
}

function toggleEntry(id) { document.getElementById(id)?.classList.toggle('expanded'); }
async function clearLogs() { if(!confirm('Clear all logs?'))return; await fetch('/dashboard/logs',{method:'DELETE'}); allLogs=[]; renderLogs(); fetchStats(); }

// ── Message modal ──────────────────────────────────────
function openModal(title,key) { document.getElementById('modal-title').textContent=title; document.getElementById('modal-text').textContent=msgStore[key]||'(no content)'; document.getElementById('msg-modal').classList.add('open'); }
function closeModalDirect() { document.getElementById('msg-modal').classList.remove('open'); }
function closeModal(e) { if(e.target===document.getElementById('msg-modal'))closeModalDirect(); }

// ── Restart ────────────────────────────────────────────
async function restartProxy() {
  if(!confirm('Restart the proxy?'))return;
  await fetch('/dashboard/restart',{method:'POST'});
  document.getElementById('status-text').textContent='Restarting…';
  setTimeout(checkStatus,2500);
}
async function checkStatus() { try{const d=await fetch('/').then(r=>r.json());if(d.ok)document.getElementById('status-text').textContent='Online';}catch{setTimeout(checkStatus,2000);} }

// ── Samplers ───────────────────────────────────────────
let samplerDefs={}, samplerConfig={};
async function fetchSamplers() {
  try {
    const model=document.getElementById('sampler-model').value;
    const data=await fetch(`/extensions/samplers/config?model=${encodeURIComponent(model)}`).then(r=>r.json());
    if(!data.ok)return;
    samplerDefs=data.defs; samplerConfig=data.config;
    renderSamplers(); drawGraph();
  } catch(e){console.error('Samplers:',e);}
}
function renderSamplers() {
  const wrap=document.getElementById('sampler-sliders'); wrap.innerHTML='';
  const keys=Object.keys(samplerDefs);
  if(!keys.length){wrap.innerHTML='<div class="empty-state" style="padding:0.8rem 0;">No samplers available for this model.</div>';return;}
  keys.forEach(key=>{
    const def=samplerDefs[key], cfg=samplerConfig[key]||{enabled:false,value:def.default};
    const row=document.createElement('div'); row.className='sampler-row';
    row.innerHTML=`<div class="sampler-row-top"><div><div class="sampler-name">${def.label}</div><div class="sampler-desc">${def.description}</div></div><label class="sampler-enable"><input type="checkbox" id="en-${key}" ${cfg.enabled?'checked':''} onchange="onSlider()"><span>Enable</span></label></div><div class="sampler-slider-row"><input type="range" id="sl-${key}" min="${def.min}" max="${def.max}" step="${def.step}" value="${cfg.value}" oninput="onSlider()" style="opacity:${cfg.enabled?1:0.4}"><span class="sampler-val" id="vl-${key}">${cfg.value}</span></div>`;
    wrap.appendChild(row);
  });
}
function onSlider() { Object.keys(samplerDefs).forEach(key=>{const sl=document.getElementById(`sl-${key}`),en=document.getElementById(`en-${key}`),vl=document.getElementById(`vl-${key}`);if(!sl||!en||!vl)return;vl.textContent=sl.value;sl.style.opacity=en.checked?'1':'0.4';}); drawGraph(); }
async function saveSamplers() {
  const payload={};
  Object.keys(samplerDefs).forEach(key=>{const sl=document.getElementById(`sl-${key}`),en=document.getElementById(`en-${key}`);if(sl&&en)payload[key]={enabled:en.checked,value:parseFloat(sl.value)};});
  try { const data=await fetch('/extensions/samplers/config',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)}).then(r=>r.json()); if(data.ok){samplerConfig=data.config;const s=document.getElementById('save-status');s.style.opacity='1';setTimeout(()=>s.style.opacity='0',2000);} } catch(e){console.error('Save:',e);}
}
function drawGraph() {
  const canvas=document.getElementById('sampler-graph'); if(!canvas)return;
  const dpr=window.devicePixelRatio||1, W=canvas.offsetWidth, H=110;
  canvas.width=W*dpr; canvas.height=H*dpr;
  const ctx=canvas.getContext('2d'); ctx.scale(dpr,dpr); ctx.clearRect(0,0,W,H);
  const N=200, probs=Array.from({length:N},(_,i)=>Math.exp(-i*.04)), sum=probs.reduce((a,b)=>a+b,0), norm=probs.map(p=>p/sum);
  const topKOn=isEn('top_k'), topPOn=isEn('top_p');
  const kLimit=topKOn?Math.min(Math.round(getSl('top_k',200)),N):N;
  let pLimit=N; if(topPOn){let cs=0;for(let i=0;i<N;i++){cs+=norm[i];if(cs>=getSl('top_p',1)){pLimit=i+1;break;}}}
  const limit=Math.min(kLimit,pLimit), bw=W/N, maxP=norm[0];
  for(let i=0;i<N;i++){
    const bh=(norm[i]/maxP)*(H-18), x=i*bw, y=H-bh-4;
    if(i<limit){const g=ctx.createLinearGradient(x,y,x,H);g.addColorStop(0,'rgba(26,111,168,0.88)');g.addColorStop(1,'rgba(13,158,138,0.38)');ctx.fillStyle=g;}
    else{ctx.fillStyle='rgba(180,210,230,0.28)';}
    ctx.beginPath(); ctx.roundRect(x+.5,y,Math.max(bw-1,1),bh,1); ctx.fill();
  }
  if(limit<N){ctx.beginPath();ctx.moveTo(limit*bw,0);ctx.lineTo(limit*bw,H-4);ctx.strokeStyle='rgba(220,60,60,0.55)';ctx.lineWidth=1.5;ctx.setLineDash([4,3]);ctx.stroke();ctx.setLineDash([]);}
  const filters=[topKOn?'Top K':'',topPOn?'Top P':''].filter(Boolean).join(', ')||'none';
  document.getElementById('sampler-graph-label').textContent=`${limit} of ${N} tokens kept (${((limit/N)*100).toFixed(0)}%) · filters: ${filters}`;
}
function getSl(key,fb){const el=document.getElementById(`sl-${key}`);return el?parseFloat(el.value):fb;}
function isEn(key){const el=document.getElementById(`en-${key}`);return el?el.checked:false;}

// ── Regex scripts ──────────────────────────────────────
let rxScripts=[], rxEditingId=null;
async function fetchRegexScripts() {
  try { const data=await fetch('/extensions/regex/scripts').then(r=>r.json()); rxScripts=data.scripts??[]; renderRegexScripts(); }
  catch { document.getElementById('regex-script-list').innerHTML='<div class="empty-state">Failed to load scripts.</div>'; }
}
function renderRegexScripts() {
  const el=document.getElementById('regex-script-list');
  if(!rxScripts.length){el.innerHTML='<div class="empty-state" style="padding:2rem 1rem;">No scripts yet. Click <strong>+ New Script</strong> to add one.</div>';return;}
  el.innerHTML='';
  rxScripts.forEach(s=>{
    const card=document.createElement('div'); card.className='rx-script-card'+(s.enabled?'':' disabled');
    card.innerHTML=`<button class="rx-toggle ${s.enabled?'on':''}" title="Toggle" onclick="rxToggle('${s.id}')"></button><div class="rx-script-info"><div class="rx-script-name">${esc(s.description||'Untitled')}</div><div class="rx-script-meta"><code>/${esc(s.findRegex)}/${esc(s.flags)}</code> → <code>${esc(s.replaceString||'(empty)')}</code>${s.trimStrings?' · trim':''}</div></div><button class="rx-edit-btn" onclick="openScriptModal('${s.id}')">✏ Edit</button>`;
    el.appendChild(card);
  });
}
async function rxToggle(id) { const s=rxScripts.find(x=>x.id===id); if(!s)return; await fetch(`/extensions/regex/scripts/${id}`,{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify({enabled:!s.enabled})}); await fetchRegexScripts(); }
function openScriptModal(id) {
  rxEditingId=id;
  const s=id?rxScripts.find(x=>x.id===id):null;
  document.getElementById('script-modal-title').textContent=s?'Edit Script':'New Script';
  document.getElementById('sm-desc').value    = s?.description??'';
  document.getElementById('sm-find').value    = s?.findRegex??'';
  document.getElementById('sm-replace').value = s?.replaceString??'';
  document.getElementById('sm-flags').value   = s?.flags??'g';
  document.getElementById('sm-trim').checked    = s?.trimStrings??false;
  document.getElementById('sm-enabled').checked = s?.enabled??true;
  document.getElementById('sm-error').style.display='none';
  document.getElementById('sm-delete-btn').style.display=s?'inline-flex':'none';
  document.getElementById('script-modal').classList.add('open');
}
function closeScriptModalDirect() { document.getElementById('script-modal').classList.remove('open'); }
function closeScriptModal(e) { if(e.target===document.getElementById('script-modal'))closeScriptModalDirect(); }
async function saveScriptModal() {
  const errEl=document.getElementById('sm-error'); errEl.style.display='none';
  const findRegex=document.getElementById('sm-find').value.trim();
  if(!findRegex){showSmError('Find (regex) is required.');return;}
  try{new RegExp(findRegex,document.getElementById('sm-flags').value);}catch(e){showSmError('Invalid regex: '+e.message);return;}
  const payload={description:document.getElementById('sm-desc').value.trim()||'Untitled',findRegex,replaceString:document.getElementById('sm-replace').value,flags:document.getElementById('sm-flags').value||'g',trimStrings:document.getElementById('sm-trim').checked,enabled:document.getElementById('sm-enabled').checked};
  try {
    if(rxEditingId){await fetch(`/extensions/regex/scripts/${rxEditingId}`,{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});}
    else{await fetch('/extensions/regex/scripts',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});}
    closeScriptModalDirect(); await fetchRegexScripts();
  } catch(e){showSmError('Save failed: '+e.message);}
}
function showSmError(msg){const el=document.getElementById('sm-error');el.textContent=msg;el.style.display='block';}
async function deleteScriptFromModal() { if(!rxEditingId||!confirm('Delete this script?'))return; await fetch(`/extensions/regex/scripts/${rxEditingId}`,{method:'DELETE'}); closeScriptModalDirect(); await fetchRegexScripts(); }
async function runTest() {
  const input = document.getElementById('test-input').value;
  if (!input) { document.getElementById('test-output').value = '⚠ Enter some input text first.'; return; }
  try { const data = await fetch('/extensions/regex/test-all', {method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({input})}).then(r=>r.json()); document.getElementById('test-output').value = data.ok ? data.output : 'Error: ' + data.error; }
  catch(e) { document.getElementById('test-output').value = 'Request failed: ' + e.message; }
}
async function regexImportHandle(e) {
  const file=e.target.files?.[0]; if(!file)return;
  try { const arr=JSON.parse(await file.text()); if(!Array.isArray(arr))throw new Error('Expected a JSON array'); await fetch('/extensions/regex/import',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(arr)}); await fetchRegexScripts(); }
  catch(e){alert('Import failed: '+e.message);}
  e.target.value='';
}
function regexExport(){const a=document.createElement('a');a.href='/extensions/regex/export';a.download='regex-scripts.json';a.click();}

// ── RAG ────────────────────────────────────────────────
let _ragConfig = {};
const RAG_SLIDERS = [
  { key:'topK',              label:'Top K',               desc:'Max chunks to inject per request',          min:1,   max:15,   step:1,    fmt: v=>v },
  { key:'queryDepth',        label:'Query Depth',         desc:'Recent user messages used as search query', min:1,   max:10,   step:1,    fmt: v=>v },
  { key:'scoreThreshold',    label:'Score Threshold',     desc:'Minimum similarity score (0–1)',            min:0,   max:1,    step:0.05, fmt: v=>parseFloat(v).toFixed(2) },
  { key:'decayHalfLife',     label:'Decay Half-Life',     desc:'Messages until relevance halves',           min:5,   max:200,  step:5,    fmt: v=>v },
  { key:'decayFloor',        label:'Decay Floor',         desc:'Minimum relevance after decay (0–1)',       min:0,   max:1,    step:0.05, fmt: v=>parseFloat(v).toFixed(2) },
  { key:'emotionBoost',      label:'Emotion Boost',       desc:'Score boost for matching emotion (0–0.5)',  min:0,   max:0.5,  step:0.05, fmt: v=>parseFloat(v).toFixed(2) },
  { key:'maxInjectionChars', label:'Max Injection Chars', desc:'Cap on injected context length',            min:500, max:6000, step:100,  fmt: v=>v },
];
async function fetchRagStatus() {
  try {
    const data = await fetch('/extensions/rag/status').then(r => r.json());
    if (!data.ok) return;
    _ragConfig = data.config;
    const s = data.stats;
    const enabled = _ragConfig.enabled;
    const btn = document.getElementById('rag-toggle-btn');
    btn.textContent = enabled ? '✓ Enabled — Click to Disable' : '✗ Disabled — Click to Enable';
    btn.className   = enabled ? 'btn' : 'btn danger';
    document.getElementById('rag-stat-char').textContent    = s.lastInjectionChar !== 'none' ? s.lastInjectionChar : '—';
    document.getElementById('rag-stat-chars').textContent   = s.lastInjectionChars || '0';
    document.getElementById('rag-stat-msg').textContent     = s.lastInjectionMsg   || '—';
    document.getElementById('rag-stat-total').textContent   = s.totalInjections    || '0';
    document.getElementById('rag-stat-indexed').textContent = s.totalIndexed       || '0';
    renderRagConfigSliders();
  } catch(e) { console.error('RAG status:', e); }
}
async function fetchRagCollections() {
  const el = document.getElementById('rag-collections');
  try {
    const data = await fetch('/extensions/rag/collections').then(r => r.json());
    if (!data.ok || !data.collections.length) { el.innerHTML = '<div class="empty-state">No collections yet. Start a roleplay to create one.</div>'; return; }
    el.innerHTML = data.collections.map(c => `<div class="rx-script-card"><div class="rx-script-info"><div class="rx-script-name">🧠 ${esc(c.char)}</div><div class="rx-script-meta">${c.chunks} chunk${c.chunks!==1?'s':''} · <code>${esc(c.name)}</code></div></div><button class="btn danger" onclick="ragClearCollection('${esc(c.name)}')">✕ Clear</button></div>`).join('');
  } catch(e) { el.innerHTML = '<div class="empty-state">Failed to load collections.</div>'; }
}
async function ragToggle() {
  try { const data = await fetch('/extensions/rag/config',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({enabled:!_ragConfig.enabled})}).then(r=>r.json()); if(data.ok){_ragConfig=data.config;fetchRagStatus();} }
  catch(e) { console.error('RAG toggle:', e); }
}
async function ragBlindNext() {
  try {
    const data = await fetch('/extensions/rag/blind-next',{method:'POST'}).then(r=>r.json());
    if(data.ok){const btn=document.getElementById('rag-blind-btn');const orig={text:btn.textContent,bg:btn.style.background,border:btn.style.borderColor,color:btn.style.color};btn.textContent='✓ Next turn protected!';btn.style.background='rgba(13,158,110,0.2)';btn.style.borderColor='rgba(13,158,110,0.5)';btn.style.color='#0a6a4a';setTimeout(()=>{btn.textContent=orig.text;btn.style.background=orig.bg;btn.style.borderColor=orig.border;btn.style.color=orig.color;},3000);}
  } catch(e) { console.error('RAG blind next:', e); }
}
async function ragClearCollection(name) {
  if(!confirm(`Clear all memory for "${name}"? This cannot be undone.`))return;
  try { const data=await fetch(`/extensions/rag/collections/${encodeURIComponent(name)}`,{method:'DELETE'}).then(r=>r.json()); if(data.ok)fetchRagCollections(); else alert('Failed to clear: '+(data.error||'unknown error')); }
  catch(e) { console.error('RAG clear:', e); }
}
function renderRagConfigSliders() {
  const wrap = document.getElementById('rag-config-sliders'); wrap.innerHTML='';
  for (const def of RAG_SLIDERS) {
    const val = _ragConfig[def.key] ?? def.min;
    const row = document.createElement('div'); row.className='rag-slider-row';
    row.innerHTML=`<div class="rag-slider-top"><div><div class="rag-slider-name">${def.label}</div><div class="rag-slider-desc">${def.desc}</div></div></div><div class="rag-slider-inner"><input type="range" id="rag-sl-${def.key}" min="${def.min}" max="${def.max}" step="${def.step}" value="${val}" oninput="ragOnSlider('${def.key}')"><span class="rag-slider-val" id="rag-vl-${def.key}">${def.fmt(val)}</span></div>`;
    wrap.appendChild(row);
  }
}
function ragOnSlider(key) { const def=RAG_SLIDERS.find(d=>d.key===key); const val=document.getElementById(`rag-sl-${key}`)?.value; if(def&&val!==undefined)document.getElementById(`rag-vl-${key}`).textContent=def.fmt(val); }
async function ragSaveConfig() {
  const payload={..._ragConfig};
  for(const def of RAG_SLIDERS){const el=document.getElementById(`rag-sl-${def.key}`);if(el)payload[def.key]=parseFloat(el.value);}
  try { const data=await fetch('/extensions/rag/config',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)}).then(r=>r.json()); if(data.ok){_ragConfig=data.config;const s=document.getElementById('rag-save-status');s.style.opacity='1';setTimeout(()=>s.style.opacity='0',2000);} }
  catch(e) { console.error('RAG save:', e); }
}

// ── TunnelVision ───────────────────────────────────────
let _tvEditorName = null;
let _tvEditorNodeId = null; // node to add entries to

async function fetchTvStatus() {
  try {
    const data = await fetch('/extensions/tunnelvision/status').then(r => r.json());
    if (!data.ok) return;
    document.getElementById('tv-stat-active').textContent  = data.activeName ?? '—';
    document.getElementById('tv-stat-nodes').textContent   = data.nodeCount ?? '—';
    document.getElementById('tv-stat-entries').textContent = data.treeExists ? (data.entryCount ?? '—') : '—';
    document.getElementById('tv-stat-trees').textContent   = data.trees?.length ?? '—';
    document.getElementById('tv-active-tree-input').placeholder = data.activeName ? `auto: ${data.activeName}` : 'auto-detect';

    // Mandatory tools button
    const mandatory = data.config?.mandatoryTools ?? false;
    const mandatoryBtn = document.getElementById('tv-mandatory-btn');
    mandatoryBtn.textContent = mandatory ? '✓ Mandatory — Click to Disable' : '✗ Off — Click to Enable';
    mandatoryBtn.className   = mandatory ? 'btn success' : 'btn';

    // Auto-summary
    const autoSummary = data.config?.autoSummary ?? false;
    const autoBtn = document.getElementById('tv-autosummary-btn');
    autoBtn.textContent = autoSummary ? '✓ Enabled — Click to Disable' : '✗ Off — Click to Enable';
    autoBtn.className   = autoSummary ? 'btn success' : 'btn';
    document.getElementById('tv-autosummary-options').style.display = autoSummary ? 'block' : 'none';
    const interval = data.config?.autoSummaryInterval ?? 20;
    document.getElementById('tv-summary-interval').value = interval;
    document.getElementById('tv-summary-interval-val').textContent = interval;
  } catch(e) { console.error('TV status:', e); }
}

async function tvToggleAutoSummary() {
  try {
    const data = await fetch('/extensions/tunnelvision/status').then(r => r.json());
    const current = data.config?.autoSummary ?? false;
    await fetch('/extensions/tunnelvision/config', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ autoSummary: !current }),
    });
    fetchTvStatus();
  } catch(e) { console.error('TV auto-summary toggle:', e); }
}

async function tvSaveAutoSummary() {
  try {
    const interval = parseInt(document.getElementById('tv-summary-interval').value, 10);
    await fetch('/extensions/tunnelvision/config', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ autoSummaryInterval: interval }),
    });
    const s = document.getElementById('tv-mandatory-btn'); // reuse save flash
    fetchTvStatus();
  } catch(e) { console.error('TV save auto-summary:', e); }
}

async function fetchTvTrees() {
  const el = document.getElementById('tv-trees-list');
  try {
    const data = await fetch('/extensions/tunnelvision/trees').then(r => r.json());
    if (!data.ok || !data.trees.length) {
      el.innerHTML = '<div class="empty-state">No trees yet. Start a roleplay and TunnelVision will auto-create one.</div>';
      return;
    }
    el.innerHTML = '';
    for (const t of data.trees) {
      const card = document.createElement('div');
      card.className = 'tv-tree-card';
      card.innerHTML = `
        <div class="tv-tree-header">
          <span class="tv-tree-name">📺 ${esc(t.name)}</span>
        </div>
        <div class="tv-tree-meta">
          <span>🗂 ${t.nodeCount} nodes</span>
          <span>📝 ${t.entryCount} entries</span>
          <span>🕐 ${t.updatedAt ? new Date(t.updatedAt).toLocaleString([],{month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'}) : '—'}</span>
        </div>
        <div style="display:flex;gap:8px;margin-top:0.75rem;flex-wrap:wrap;">
          <button class="btn primary" onclick="openTvEditor('${esc(t.name)}')" style="font-size:0.76rem;">✏ Edit Tree</button>
          <button class="btn danger" onclick="tvDeleteTree('${esc(t.name)}')" style="font-size:0.76rem;">✕ Delete</button>
        </div>`;
      el.appendChild(card);
    }
  } catch(e) { el.innerHTML = '<div class="empty-state">Failed to load trees.</div>'; }
}

async function openTvEditor(name) {
  _tvEditorName = name;
  document.getElementById('tv-editor-name').textContent = name;
  document.getElementById('tv-editor-card').style.display = 'block';
  document.getElementById('tv-editor-card').scrollIntoView({ behavior: 'smooth', block: 'start' });
  await fetchTvTree(name);
}

async function fetchTvTree(name) {
  const el = document.getElementById('tv-tree-nodes');
  try {
    const data = await fetch(`/extensions/tunnelvision/tree/${encodeURIComponent(name)}`).then(r => r.json());
    if (!data.ok) { el.innerHTML = '<div class="empty-state">Failed to load tree.</div>'; return; }
    renderTvTree(data.tree);
  } catch(e) { el.innerHTML = '<div class="empty-state">Failed to load tree.</div>'; }
}

function renderTvTree(tree) {
  const el = document.getElementById('tv-tree-nodes');
  el.innerHTML = '';
  if (!tree?.nodes) { el.innerHTML = '<div class="empty-state">Empty tree.</div>'; return; }

  // Render root children
  const root = tree.nodes[tree.rootId];
  if (!root) return;

  function renderNode(nodeId, depth) {
    const node = tree.nodes[nodeId];
    if (!node) return null;

    const row = document.createElement('div');
    row.className = 'tv-node-row';
    row.style.marginLeft = depth > 0 ? `${depth * 16}px` : '0';

    const entries = node.entries || [];
    const enabledEntries = entries.filter(e => e.enabled !== false);
    const childCount = node.children.length;
    const totalItems = enabledEntries.length + childCount;

    const icon = node.isArc ? '🎬' : nodeId === tree.summariesId ? '📋' : nodeId === tree.rootId ? '🌳' : '📺';

    row.innerHTML = `
      <div class="tv-node-header" onclick="this.closest('.tv-node-row').classList.toggle('expanded')">
        <span class="tv-node-icon">${icon}</span>
        <span class="tv-node-label">${esc(node.label)}</span>
        ${totalItems > 0 ? `<span class="tv-node-count">${enabledEntries.length} entries${childCount > 0 ? ` · ${childCount} sub` : ''}</span>` : ''}
        <span class="tv-node-toggle">▶</span>
      </div>
      ${node.summary ? `<div class="tv-summary">${esc(node.summary)}</div>` : ''}
      <div class="tv-node-entries">
        <div style="display:flex;gap:6px;margin-bottom:0.6rem;flex-wrap:wrap;">
          <button class="btn primary" style="font-size:0.7rem;padding:3px 10px;" onclick="openTvEntryModal('${esc(tree.charName)}','${esc(nodeId)}')">+ Add Entry</button>
        </div>
        <div id="tv-entries-${esc(nodeId)}">${renderEntries(enabledEntries, tree.charName, nodeId)}</div>
      </div>`;

    el.appendChild(row);

    // Render children recursively
    for (const cid of node.children) {
      renderNode(cid, depth + 1);
    }
  }

  // Render root entries if any
  const rootEntries = (root.entries || []).filter(e => e.enabled !== false);
  if (rootEntries.length > 0) renderNode(tree.rootId, 0);

  // Render root's children
  for (const cid of root.children) renderNode(cid, 0);
}

function renderEntries(entries, charName, nodeId) {
  if (!entries.length) return '<div style="font-size:0.72rem;color:#8aaaaа;padding:4px 0;">No entries yet.</div>';
  return entries.map(e => `
    <div class="tv-entry-row ${e.enabled===false?'tv-entry-disabled':''}">
      <span class="tv-entry-uid">#${e.uid}</span>
      <div class="tv-entry-info">
        <div class="tv-entry-title">${esc(e.title)}</div>
        <div class="tv-entry-content">${esc(e.content.slice(0, 200))}${e.content.length > 200 ? '…' : ''}</div>
        ${e.keys?.length ? `<div class="tv-entry-keys">${e.keys.map(k=>`<span class="tv-entry-key">${esc(k)}</span>`).join('')}</div>` : ''}
      </div>
    </div>`).join('');
}

async function tvSetActiveTree() {
  const name = document.getElementById('tv-active-tree-input').value.trim();
  try {
    await fetch('/extensions/tunnelvision/config', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ activeTree: name || null }) });
    fetchTvStatus();
  } catch(e) { console.error('TV set active:', e); }
}

async function tvClearActiveTree() {
  document.getElementById('tv-active-tree-input').value = '';
  try {
    await fetch('/extensions/tunnelvision/config', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ activeTree: null }) });
    fetchTvStatus();
  } catch(e) { console.error('TV clear active:', e); }
}

async function tvDeleteTree(name) {
  if (!confirm(`Delete tree "${name}"? This cannot be undone.`)) return;
  try {
    await fetch(`/extensions/tunnelvision/tree/${encodeURIComponent(name)}`, { method: 'DELETE' });
    if (_tvEditorName === name) { _tvEditorName = null; document.getElementById('tv-editor-card').style.display = 'none'; }
    fetchTvStatus(); fetchTvTrees();
  } catch(e) { console.error('TV delete:', e); }
}

// TunnelVision Add Channel modal
function openTvNodeModal() {
  document.getElementById('tv-nm-label').value = '';
  document.getElementById('tv-nm-summary').value = '';
  document.getElementById('tv-nm-error').style.display = 'none';
  document.getElementById('tv-node-modal').classList.add('open');
}
function closeTvNodeModalDirect() { document.getElementById('tv-node-modal').classList.remove('open'); }
function closeTvNodeModal(e) { if(e.target===document.getElementById('tv-node-modal'))closeTvNodeModalDirect(); }
async function saveTvNode() {
  const label = document.getElementById('tv-nm-label').value.trim();
  const summary = document.getElementById('tv-nm-summary').value.trim();
  const errEl = document.getElementById('tv-nm-error');
  if (!label) { errEl.textContent = 'Channel name is required.'; errEl.style.display = 'block'; return; }
  if (!_tvEditorName) { errEl.textContent = 'No tree selected.'; errEl.style.display = 'block'; return; }
  try {
    const data = await fetch(`/extensions/tunnelvision/tree/${encodeURIComponent(_tvEditorName)}/node`, {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ label, summary }),
    }).then(r => r.json());
    if (!data.ok) { errEl.textContent = data.error || 'Failed.'; errEl.style.display = 'block'; return; }
    closeTvNodeModalDirect();
    fetchTvTree(_tvEditorName);
    fetchTvStatus();
  } catch(e) { errEl.textContent = e.message; errEl.style.display = 'block'; }
}

// TunnelVision Add Entry modal
function openTvEntryModal(charName, nodeId) {
  _tvEditorName = charName;
  _tvEditorNodeId = nodeId;
  document.getElementById('tv-entry-modal-title').textContent = 'Add Entry';
  document.getElementById('tv-em-title').value = '';
  document.getElementById('tv-em-content').value = '';
  document.getElementById('tv-em-keys').value = '';
  document.getElementById('tv-em-error').style.display = 'none';
  document.getElementById('tv-entry-modal').classList.add('open');
}
function closeTvEntryModalDirect() { document.getElementById('tv-entry-modal').classList.remove('open'); }
function closeTvEntryModal(e) { if(e.target===document.getElementById('tv-entry-modal'))closeTvEntryModalDirect(); }
async function saveTvEntry() {
  const title   = document.getElementById('tv-em-title').value.trim();
  const content = document.getElementById('tv-em-content').value.trim();
  const keys    = document.getElementById('tv-em-keys').value.split(',').map(k=>k.trim()).filter(Boolean);
  const errEl   = document.getElementById('tv-em-error');
  if (!title)   { errEl.textContent = 'Title is required.';   errEl.style.display = 'block'; return; }
  if (!content) { errEl.textContent = 'Content is required.'; errEl.style.display = 'block'; return; }
  try {
    const data = await fetch(`/extensions/tunnelvision/tree/${encodeURIComponent(_tvEditorName)}/node/${encodeURIComponent(_tvEditorNodeId)}/entry`, {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ title, content, keys }),
    }).then(r => r.json());
    if (!data.ok) { errEl.textContent = data.error || 'Failed.'; errEl.style.display = 'block'; return; }
    closeTvEntryModalDirect();
    fetchTvTree(_tvEditorName);
    fetchTvStatus();
  } catch(e) { errEl.textContent = e.message; errEl.style.display = 'block'; }
}

// ── Helpers ────────────────────────────────────────────
function esc(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}

// ── Init ───────────────────────────────────────────────
fetchStats();
fetchHealth();
setInterval(fetchStats, 30000);
setInterval(fetchHealth, 10000);
</script>
</body>
</html>